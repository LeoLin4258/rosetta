# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Sidecar binaries + bundled tokenizer resources fetched at build time by
# scripts/fetch-rwkv-sidecar.sh. The actual artifacts are produced by the
# Build RWKV sidecar (macOS arm64) workflow and shipped via tagged GitHub
# releases — never commit them. .gitkeep files in each directory are kept.
/binaries/*
!/binaries/.gitkeep
/resources/rwkv-sidecar/*
!/resources/rwkv-sidecar/.gitkeep
