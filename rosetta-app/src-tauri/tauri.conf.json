{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rosetta",
  "version": "0.1.0-beta.1",
  "identifier": "com.rosetta.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rosetta",
        "width": 1280,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "shadow": true,
        "theme": "Dark",
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        },
        "visible": false
      },
      {
        "label": "onboarding",
        "title": "Welcome to Rosetta",
        "width": 720,
        "height": 560,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "center": true,
        "decorations": false,
        "shadow": true,
        "theme": "Dark",
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        },
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/jobs/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNEIyODAxNTZBNDYwRTQKUldUa1lLUldBU2hMNy9jbStlRkoxVE1XTFNDK0dFTnpmeFptOWxSd1lEb3dObk1Fd01uZ2ZJcm0K",
      "endpoints": [
        "https://github.com/LeoLin4258/rosetta/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
